{
  "name": "hackbox-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "build": "npm install && npx tsc && npm run sentry:sourcemaps",
    "start": "node dist/index.js",
    "dev": "PORT=9000 concurrently \"npx tsc --watch\" \"nodemon dist/index.js\"",
    "update-server": "git fetch && git reset --hard origin/main && npm run build && PORT=3000 npm run start",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org hackbox --project game-server ./dist && sentry-cli sourcemaps upload --org hackbox --project game-server ./dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/instrumentation-socket.io": "^0.43.0",
    "@sentry/cli": "^2.38.0",
    "@sentry/node": "^8.35.0",
    "@sentry/profiling-node": "^8.35.0",
    "@types/lodash": "^4.17.12",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.35.3",
    "express": "^4.21.1",
    "lodash": "^4.17.21",
    "postgres": "^3.4.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.2",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.26.2",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.12.1"
  }
}
