{
  "name": "hackbox-game-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "build": "npm install && npx tsc && npm run sentry:sourcemaps",
    "start": "node dist/index.js",
    "dev": "PORT=9000 tsx --watch index.ts",
    "update-server": "git fetch && git reset --hard origin/main && npm run build && PORT=3000 npm run start",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org hackbox --project game-server ./dist && sentry-cli sourcemaps upload --org hackbox --project game-server ./dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.35.0",
    "@sentry/profiling-node": "^10.35.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "lodash": "^4.17.21",
    "postgres": "^3.4.8",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.0.9",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.13.0"
  }
}
