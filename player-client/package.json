    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@sentry/vite-plugin": "^4.7.0",
    "@sentry/vue": "^10.35.0",
    "dompurify": "^3.3.1",
    "lodash": "^4.17.21",
    "marked": "^17.0.1",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.27",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.15.0",
