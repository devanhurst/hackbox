{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hackbox",
  "main": "party.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "HackboxParty",
        "class_name": "HackboxParty"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["HackboxParty"]
    }
  ]
}
