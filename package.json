{
  "name": "hackbox",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/devanhurst/hackbox#readme",
  "bugs": {
    "url": "https://github.com/devanhurst/hackbox/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devanhurst/hackbox.git"
  },
  "main": "index.js",
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:docs": "cd docs && npm run dev",
    "dev": "concurrently -n \"server,client,docs\" -c \"blue,magenta,green\" \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:docs\"",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "npm run lint",
    "*": "npm run fmt -- --no-error-on-unmatched-pattern"
  }
}
