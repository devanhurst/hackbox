{
  "name": "hackbox",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/devanhurst/hackbox#readme",
  "bugs": {
    "url": "https://github.com/devanhurst/hackbox/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devanhurst/hackbox.git"
  },
  "main": "index.js",
  "scripts": {
    "dev:player": "cd player-client && npm run dev",
    "dev:server": "cd game-server && npm run dev",
    "dev:docs": "cd docs && npm run dev",
    "dev": "concurrently -n \"server,player,docs\" -c \"blue,magenta,green\" \"npm run dev:server\" \"npm run dev:player\" \"npm run dev:docs\"",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "oxlint-tsgolint": "^0.11.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "npm run lint",
    "*": "npm run fmt -- --no-error-on-unmatched-pattern"
  }
}
